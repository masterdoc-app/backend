ONYX_BASE_URL=http://127.0.0.1:3000/api
ONYX_PAT=onyx_pat_...
PORT=8081
# SQLite path for case reports (transcript + result text)
REPORTS_DB_PATH=/opt/masterdoc-backend/data/case-reports.db
# Reports API (see README):
# POST /v1/report  — save result + transcript
# GET  /v1/report?assistant_id=1&page=0&size=20  — list by station, newest first
# GET  /v1/report/search (planned) — q + assistant_id + pagination
# Onyx persona id for assistant detection (/app?agentId=3 → persona 3)
DETECT_PERSONA_ID=3
# Force internal search on every chat message (default: true)
ONYX_FORCE_INTERNAL_SEARCH=true
# Optional: numeric Onyx tool id; if unset, resolved once via GET /tool (SearchTool)
# ONYX_SEARCH_TOOL_ID=1
